        tasks = []
        # Try finding all elements ending in 'Task'
        for elem in root.iter():
            if elem.tag.endswith('Task'):
                tasks.append(elem)
        
        for task in tasks:
            data = {}
            for child in task:
                tag = child.tag.split('}')[-1] # Strip NS
