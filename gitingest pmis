        NONE = 'NONE', 'None'
        VALIDATE = 'VALIDATE', 'Validate Document'
        APPROVE = 'APPROVE', 'Approve Document'
        REJECT = 'REJECT', 'Reject Document'
        REQUEST_REVISION = 'REQUEST_REVISION', 'Request Revision'
    
